{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u535a\u5ba2\uff01","text":"<p>\u8fd9\u91cc\u662f\u6211\u7684\u4e2a\u4eba\u535a\u5ba2\uff0c\u7528\u6765\u6574\u7406\u6280\u672f\u7b14\u8bb0\u3001\u9879\u76ee\u590d\u76d8\u548c\u4e00\u4e9b\u6b63\u5728\u5b66\u4e60\u4e2d\u7684\u60f3\u6cd5\u3002\u5185\u5bb9\u4f1a\u6162\u6162\u957f\u51fa\u6765\uff0c\u5148\u4ece\u53ef\u8bfb\u3001\u6e05\u723d\u3001\u65b9\u4fbf\u7ef4\u62a4\u5f00\u59cb\u3002</p> <p>\u9605\u8bfb\u6587\u7ae0 \u4e86\u89e3\u6211</p>"},{"location":"#_2","title":"\u6700\u8fd1\u66f4\u65b0","text":""},{"location":"#chapter-5","title":"\u8ba1\u7b97\u673a\u7ec4\u6210\u539f\u7406 Chapter 5","text":"<p>\u6574\u7406\u5b58\u50a8\u5c42\u6b21\u3001Cache\u3001\u865a\u62df\u5185\u5b58\u3001\u9875\u8868\u3001Page Fault \u548c TLB\uff0c\u628a\u5185\u5b58\u7cfb\u7edf\u8fd9\u6761\u7ebf\u4e32\u8d77\u6765\u3002</p> <p>\u7ee7\u7eed\u9605\u8bfb</p>"},{"location":"#chapter-6","title":"\u8ba1\u7b97\u673a\u7ec4\u6210\u539f\u7406 Chapter 6","text":"<p>\u6574\u7406\u53ef\u9760\u6027\u6307\u6807\u3001RAID \u78c1\u76d8\u9635\u5217\u548c\u603b\u7ebf\u901a\u4fe1\u673a\u5236\uff0c\u628a\u8bfe\u5802\u8981\u70b9\u8865\u6210\u53ef\u590d\u4e60\u7684\u7b14\u8bb0\u3002</p> <p>\u7ee7\u7eed\u9605\u8bfb</p>"},{"location":"#_3","title":"\u7b2c\u4e8c\u7bc7\u6587\u7ae0","text":"<p>\u7ed9\u81ea\u5df1\u7559\u4e00\u5757\u5b9e\u9a8c\u7530\uff0c\u4e4b\u540e\u53ef\u4ee5\u653e\u5b66\u4e60\u7b14\u8bb0\u3001\u9879\u76ee\u7247\u6bb5\u6216\u8e29\u5751\u8bb0\u5f55\u3002</p> <p>\u7ee7\u7eed\u9605\u8bfb</p>"},{"location":"#_4","title":"\u4ee3\u7801\u7247\u6bb5","text":"<pre><code>#include &lt;iostream&gt;\n\nint main() {\n    std::cout &lt;&lt; \"Hello, blog!\";\n    return 0;\n}\n</code></pre>"},{"location":"about/","title":"\u5173\u4e8e\u6211","text":"<p>\u4f60\u597d\uff0c\u6211\u662f\u8fd9\u4e2a\u535a\u5ba2\u7684\u7ef4\u62a4\u8005\u3002</p> <p>\u8fd9\u4e2a\u7ad9\u70b9\u4f1a\u7528\u6765\u5b58\u653e\u6211\u5728\u7f16\u7a0b\u3001\u5de5\u5177\u3001\u9879\u76ee\u548c\u65e5\u5e38\u5b66\u4e60\u91cc\u7684\u8bb0\u5f55\u3002\u76f8\u6bd4\u8ffd\u6c42\u4e00\u6b21\u5199\u5f97\u5f88\u5b8c\u6574\uff0c\u6211\u66f4\u5e0c\u671b\u5b83\u80fd\u6301\u7eed\u66f4\u65b0\uff1a\u628a\u60f3\u6cd5\u5148\u7559\u4e0b\uff0c\u518d\u6162\u6162\u6253\u78e8\u6210\u66f4\u6e05\u695a\u7684\u6587\u7ae0\u3002</p>"},{"location":"about/#_2","title":"\u8fd9\u91cc\u4f1a\u5199\u4ec0\u4e48","text":"<ul> <li>\u6280\u672f\u5b66\u4e60\u7b14\u8bb0</li> <li>\u9879\u76ee\u642d\u5efa\u548c\u95ee\u9898\u590d\u76d8</li> <li>\u7f16\u7a0b\u8bed\u8a00\u3001\u5de5\u5177\u94fe\u548c\u6548\u7387\u7ecf\u9a8c</li> <li>\u5076\u5c14\u4e5f\u4f1a\u6709\u4e00\u4e9b\u751f\u6d3b\u89c2\u5bdf</li> </ul>"},{"location":"about/#_3","title":"\u8054\u7cfb\u4e0e\u4ea4\u6d41","text":"<p>\u5982\u679c\u67d0\u7bc7\u6587\u7ae0\u521a\u597d\u5e2e\u5230\u4f60\uff0c\u6216\u8005\u4f60\u53d1\u73b0\u4e86\u53ef\u4ee5\u6539\u8fdb\u7684\u5730\u65b9\uff0c\u6b22\u8fce\u5728\u6587\u7ae0\u4e0b\u65b9\u8bc4\u8bba\u533a\u4ea4\u6d41\u3002</p>"},{"location":"posts/second-post/","title":"\u7b2c\u4e8c\u7bc7\u6587\u7ae0","text":"<p>\u8fd9\u7bc7\u6587\u7ae0\u6682\u65f6\u4f5c\u4e3a\u5360\u4f4d\uff0c\u7528\u6765\u6d4b\u8bd5\u535a\u5ba2\u7684\u6587\u7ae0\u5217\u8868\u3001\u5bfc\u822a\u548c\u6392\u7248\u6548\u679c\u3002</p>"},{"location":"posts/second-post/#_2","title":"\u53ef\u4ee5\u653e\u4ec0\u4e48","text":"<p>\u4e4b\u540e\u8fd9\u91cc\u53ef\u4ee5\u5199\uff1a</p> <ul> <li>\u4e00\u4e2a\u9879\u76ee\u7684\u5f00\u53d1\u8bb0\u5f55</li> <li>\u67d0\u4e2a\u6280\u672f\u6982\u5ff5\u7684\u5b66\u4e60\u7b14\u8bb0</li> <li>\u4e00\u6b21\u95ee\u9898\u6392\u67e5\u7684\u5b8c\u6574\u8fc7\u7a0b</li> </ul> <pre><code>const blog = {\n  name: \"My Blog\",\n  status: \"growing\",\n};\n\nconsole.log(`${blog.name} is ${blog.status}.`);\n</code></pre>"},{"location":"posts/second-post/#_3","title":"\u7ee7\u7eed\u751f\u957f","text":"<p>\u597d\u7684\u535a\u5ba2\u4e0d\u662f\u4e00\u5929\u5b8c\u6210\u7684\u3002\u5148\u8ba9\u7ed3\u6784\u6e05\u695a\uff0c\u518d\u8ba9\u5185\u5bb9\u6162\u6162\u53d8\u539a\u3002</p>"},{"location":"posts/computer-organization/chapter5/","title":"\u8ba1\u7b97\u673a\u7ec4\u6210\u539f\u7406 Chapter 5\uff1a\u5b58\u50a8\u5c42\u6b21\u3001Cache \u4e0e\u865a\u62df\u5185\u5b58","text":"<p>\u8fd9\u4e00\u7ae0\u7684\u4e3b\u7ebf\u662f memory hierarchy\uff1aCPU \u5f88\u5feb\uff0c\u4e3b\u5b58\u548c\u78c1\u76d8\u76f8\u5bf9\u6162\u5f97\u591a\uff0c\u6240\u4ee5\u8ba1\u7b97\u673a\u7cfb\u7edf\u9700\u8981\u7528\u5206\u5c42\u7ed3\u6784\u628a\u201c\u5feb\u4f46\u8d35\u7684\u5c0f\u5bb9\u91cf\u5b58\u50a8\u201d\u548c\u201c\u6162\u4f46\u4fbf\u5b9c\u7684\u5927\u5bb9\u91cf\u5b58\u50a8\u201d\u7ec4\u5408\u8d77\u6765\u3002</p> <p>\u53ef\u4ee5\u628a\u672c\u7ae0\u5206\u6210\u4e09\u5c42\u7406\u89e3\uff1a</p> <ul> <li>\u5b58\u50a8\u5668\u5c42\u6b21\uff1a\u4e3a\u4ec0\u4e48\u8981\u7528 SRAM\u3001DRAM\u3001Flash\u3001\u78c1\u76d8\u5206\u5c42\u3002</li> <li>Cache\uff1a\u600e\u6837\u5229\u7528\u5c40\u90e8\u6027\u8ba9\u5904\u7406\u5668\u591a\u6570\u65f6\u5019\u8bbf\u95ee\u66f4\u5feb\u7684\u5b58\u50a8\u3002</li> <li>\u865a\u62df\u5185\u5b58\uff1a\u600e\u6837\u8ba9\u4e3b\u5b58\u50cf\u78c1\u76d8\u7684 Cache\uff0c\u5e76\u4e3a\u7a0b\u5e8f\u63d0\u4f9b\u72ec\u7acb\u7684\u5730\u5740\u7a7a\u95f4\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter5/#_1","title":"\u5b58\u50a8\u5668\u7684\u57fa\u672c\u7c7b\u578b","text":"<p>\u968f\u7740\u5904\u7406\u5668\u901f\u5ea6\u5feb\u901f\u63d0\u5347\uff0c\u5185\u5b58\u8bbf\u95ee\u901f\u5ea6\u6ca1\u6709\u4ee5\u540c\u6837\u901f\u5ea6\u589e\u957f\uff0cCPU \u7ecf\u5e38\u9700\u8981\u7b49\u5f85\u6570\u636e\u3002\u5b58\u50a8\u7cfb\u7edf\u7684\u8bbe\u8ba1\u76ee\u6807\u5c31\u662f\u5728\u6210\u672c\u53ef\u63a5\u53d7\u7684\u524d\u63d0\u4e0b\uff0c\u5c3d\u91cf\u964d\u4f4e\u5e73\u5747\u8bbf\u95ee\u65f6\u95f4\u3002</p> <p>\u5e38\u89c1\u5b58\u50a8\u5668\u53ef\u4ee5\u6309\u901f\u5ea6\u3001\u4ef7\u683c\u548c\u5bb9\u91cf\u5927\u81f4\u5206\u5c42\uff1a</p> \u7c7b\u578b \u662f\u5426\u6613\u5931 \u5178\u578b\u7528\u9014 \u7279\u70b9 SRAM \u6613\u5931 CPU \u5185\u90e8 Cache \u5f88\u5feb\u3001\u4ef7\u683c\u9ad8\u3001\u5bb9\u91cf\u5c0f DRAM \u6613\u5931 \u4e3b\u5b58 RAM \u5bb9\u91cf\u8f83\u5927\u3001\u9700\u8981\u5237\u65b0\u3001\u901f\u5ea6\u4f4e\u4e8e SRAM Flash \u975e\u6613\u5931 SSD\u3001U \u76d8 \u65ad\u7535\u4fdd\u5b58\u3001\u8bfb\u5199\u901f\u5ea6\u4ecb\u4e8e DRAM \u548c\u78c1\u76d8\u4e4b\u95f4 Magnetic Disk \u975e\u6613\u5931 \u673a\u68b0\u786c\u76d8 \u5bb9\u91cf\u5927\u3001\u4ef7\u683c\u4f4e\u3001\u673a\u68b0\u8bbf\u95ee\u5ef6\u8fdf\u9ad8"},{"location":"posts/computer-organization/chapter5/#dram","title":"DRAM","text":"<p><code>DRAM</code> \u662f\u52a8\u6001\u968f\u673a\u5b58\u53d6\u5b58\u50a8\u5668\u3002\u5b83\u7528\u7535\u5bb9\u4e2d\u7684\u7535\u8377\u8868\u793a\u6570\u636e\uff0c\u4f46\u7535\u8377\u4f1a\u9010\u6e10\u6cc4\u6f0f\uff0c\u6240\u4ee5\u5fc5\u987b\u5468\u671f\u6027\u5237\u65b0\u3002\u5237\u65b0\u4f1a\u5e26\u6765\u989d\u5916\u5f00\u9500\uff0c\u56e0\u6b64 DRAM \u6bd4 SRAM \u6162\u3002</p> <p>DRAM \u7684\u8bfb\u53d6\u901a\u5e38\u662f\u7834\u574f\u6027\u7684\uff0c\u8bfb\u51fa\u540e\u9700\u8981\u628a\u6570\u636e\u91cd\u65b0\u5199\u56de\u3002\u4e00\u822c\u8bf4\u7684\u201c\u5185\u5b58\u6761\u201d\u4e3b\u8981\u5c31\u662f DRAM\u3002\u73b0\u4ee3 DRAM \u5f15\u5165\u65f6\u949f\u4fe1\u53f7\u548c\u6d41\u6c34\u5316\u7ec4\u7ec7\uff0c\u56e0\u6b64\u4e5f\u5e38\u89c1 <code>SDRAM</code> \u8fd9\u7c7b\u540d\u79f0\u3002</p>"},{"location":"posts/computer-organization/chapter5/#sram","title":"SRAM","text":"<p><code>SRAM</code> \u662f\u9759\u6001\u968f\u673a\u5b58\u53d6\u5b58\u50a8\u5668\u3002\u5b83\u7528\u591a\u4e2a\u6676\u4f53\u7ba1\u6784\u6210\u9501\u5b58\u7ed3\u6784\uff0c\u53ea\u8981\u6301\u7eed\u4f9b\u7535\uff0c\u6570\u636e\u5c31\u80fd\u4fdd\u6301\uff0c\u4e0d\u9700\u8981\u50cf DRAM \u90a3\u6837\u5237\u65b0\u3002</p> <p>SRAM \u7684\u901f\u5ea6\u5feb\uff0c\u4f46\u9762\u79ef\u548c\u6210\u672c\u9ad8\uff0c\u6240\u4ee5\u901a\u5e38\u96c6\u6210\u5728 CPU \u5185\u90e8\u4f5c\u4e3a L1\u3001L2\u3001L3 Cache\u3002</p>"},{"location":"posts/computer-organization/chapter5/#flash","title":"Flash \u4e0e\u78c1\u76d8","text":"<p><code>Flash</code> \u662f\u975e\u6613\u5931\u6027\u5b58\u50a8\uff0c\u65ad\u7535\u540e\u6570\u636e\u4ecd\u7136\u4fdd\u7559\uff0c\u5e38\u7528\u4e8e SSD \u548c U \u76d8\u3002</p> <p>\u673a\u68b0\u78c1\u76d8\u7531\u76d8\u7247\u3001\u78c1\u9053\u3001\u6247\u533a\u548c\u78c1\u5934\u7ec4\u6210\uff1a</p> <ul> <li><code>track</code>\uff1a\u78c1\u9053\uff0c\u76d8\u7247\u8868\u9762\u7684\u540c\u5fc3\u5706\u3002</li> <li><code>sector</code>\uff1a\u6247\u533a\uff0c\u78c1\u9053\u4e0a\u7684\u4e00\u6bb5\uff0c\u662f\u78c1\u76d8\u5e38\u89c1\u7684\u6700\u5c0f\u7269\u7406\u8bfb\u5199\u5355\u5143\u3002</li> <li><code>cylinder</code>\uff1a\u67f1\u9762\uff0c\u591a\u5f20\u76d8\u7247\u4e0a\u534a\u5f84\u76f8\u540c\u7684\u78c1\u9053\u96c6\u5408\u3002</li> </ul> <p>\u78c1\u76d8\u8bbf\u95ee\u65f6\u95f4\u901a\u5e38\u7531\u4ee5\u4e0b\u90e8\u5206\u7ec4\u6210\uff1a</p> \\[ Disk\\ Access\\ Time = Seek\\ Time + Rotational\\ Latency + Transfer\\ Time + Controller\\ Overhead \\] <p>\u4f8b\u5982\uff1a512B sector\u300115000rpm\u3001\u5e73\u5747\u5bfb\u9053 4ms\u3001\u4f20\u8f93\u7387 100MB/s\u3001\u63a7\u5236\u5668\u5f00\u9500 0.2ms\u3002</p> <p>\u5e73\u5747\u65cb\u8f6c\u5ef6\u8fdf\u7ea6\u4e3a\u534a\u5708\uff1a</p> \\[ \\frac{0.5}{15000 / 60} = 0.002s = 2ms \\] <p>\u4f20\u8f93 512B \u7684\u65f6\u95f4\u975e\u5e38\u5c0f\uff0c\u7ea6\u4e3a\uff1a</p> \\[ \\frac{512B}{100MB/s} \\approx 0.005ms \\] <p>\u6240\u4ee5\u603b\u65f6\u95f4\u5927\u7ea6\u4e3a\uff1a</p> \\[ 4ms + 2ms + 0.2ms + 0.005ms \\approx 6.2ms \\] <p>\u8fd9\u8bf4\u660e\u673a\u68b0\u78c1\u76d8\u7684\u4e3b\u8981\u5f00\u9500\u6765\u81ea\u5bfb\u9053\u548c\u65cb\u8f6c\u5ef6\u8fdf\uff0c\u800c\u4e0d\u662f\u5b9e\u9645\u4f20\u8f93\u90a3\u51e0\u767e\u5b57\u8282\u7684\u65f6\u95f4\u3002</p>"},{"location":"posts/computer-organization/chapter5/#_2","title":"\u5b58\u50a8\u5668\u5c42\u6b21\u7ed3\u6784","text":"<p>\u8d8a\u9760\u8fd1 CPU \u7684\u5b58\u50a8\u5668\u901f\u5ea6\u8d8a\u5feb\u3001\u5bb9\u91cf\u8d8a\u5c0f\u3001\u4ef7\u683c\u8d8a\u9ad8\uff1b\u8d8a\u8fdc\u79bb CPU \u7684\u5b58\u50a8\u5668\u5bb9\u91cf\u8d8a\u5927\u3001\u4ef7\u683c\u8d8a\u4f4e\u3001\u901f\u5ea6\u8d8a\u6162\u3002</p> <p>\u5178\u578b\u5c42\u6b21\u5982\u4e0b\uff1a</p> <ol> <li>Registers</li> <li>L1 Cache</li> <li>L2/L3 Cache</li> <li>Main Memory</li> <li>SSD / Disk</li> </ol> <p>\u5b58\u50a8\u5c42\u6b21\u7ed3\u6784\u4f9d\u8d56 \u5c40\u90e8\u6027\u539f\u7406\uff1a</p> <ul> <li>\u65f6\u95f4\u5c40\u90e8\u6027\uff1a\u521a\u88ab\u8bbf\u95ee\u7684\u6570\u636e\uff0c\u77ed\u65f6\u95f4\u5185\u5f88\u53ef\u80fd\u518d\u6b21\u88ab\u8bbf\u95ee\u3002</li> <li>\u7a7a\u95f4\u5c40\u90e8\u6027\uff1a\u67d0\u4e2a\u5730\u5740\u9644\u8fd1\u7684\u6570\u636e\uff0c\u5f88\u53ef\u80fd\u5f88\u5feb\u4e5f\u4f1a\u88ab\u8bbf\u95ee\u3002</li> </ul> <p>\u5728\u4efb\u610f\u76f8\u90bb\u4e24\u5c42\u4e4b\u95f4\uff0c\u6570\u636e\u4ee5\u56fa\u5b9a\u5927\u5c0f\u7684\u5355\u4f4d\u590d\u5236\u3002\u8fd9\u4e2a\u5355\u4f4d\u901a\u5e38\u53eb <code>block</code> \u6216 <code>line</code>\u3002\u4e00\u4e2a block \u5f80\u5f80\u5305\u542b\u591a\u4e2a word\uff0c\u6240\u4ee5\u627e\u5230 block \u540e\uff0c\u8fd8\u9700\u8981\u7528 <code>offset</code> \u6307\u51fa\u5177\u4f53\u8bbf\u95ee block \u5185\u7684\u54ea\u4e00\u4e2a\u5b57\u8282\u6216\u5b57\u3002</p>"},{"location":"posts/computer-organization/chapter5/#hitmiss","title":"Hit\u3001Miss \u4e0e\u5e73\u5747\u8bbf\u95ee\u65f6\u95f4","text":"<p>\u5982\u679c\u5904\u7406\u5668\u9700\u8981\u7684\u6570\u636e\u5df2\u7ecf\u5728\u9ad8\u5c42\u5b58\u50a8\u4e2d\uff0c\u79f0\u4e3a <code>hit</code>\u3002\u5982\u679c\u9ad8\u5c42\u6ca1\u6709\u627e\u5230\uff0c\u9700\u8981\u53bb\u4f4e\u5c42\u53d6\u56de\uff0c\u79f0\u4e3a <code>miss</code>\u3002</p> <p>\u5e38\u89c1\u6982\u5ff5\uff1a</p> <ul> <li><code>hit time</code>\uff1a\u547d\u4e2d\u65f6\u8bbf\u95ee\u9ad8\u5c42\u5b58\u50a8\u6240\u9700\u7684\u65f6\u95f4\uff0c\u4e5f\u5305\u62ec\u5224\u65ad\u662f\u5426\u547d\u4e2d\u7684\u65f6\u95f4\u3002</li> <li><code>miss penalty</code>\uff1a\u7f3a\u5931\u540e\uff0c\u4ece\u4f4e\u5c42\u53d6\u56de block\u3001\u586b\u5165\u9ad8\u5c42\u5e76\u628a\u6570\u636e\u4ea4\u7ed9\u5904\u7406\u5668\u7684\u65f6\u95f4\u3002</li> <li><code>miss rate</code>\uff1a\u8bbf\u95ee\u4e2d\u53d1\u751f miss \u7684\u6bd4\u4f8b\u3002</li> </ul> <p>\u5e73\u5747\u8bbf\u95ee\u65f6\u95f4\u53ef\u4ee5\u5199\u6210\uff1a</p> \\[ AMAT = Hit\\ Time + Miss\\ Rate \\times Miss\\ Penalty \\] <p>\u8fd9\u4e5f\u662f Cache \u8bbe\u8ba1\u4e2d\u975e\u5e38\u91cd\u8981\u7684\u516c\u5f0f\u3002\u5373\u4f7f\u547d\u4e2d\u65f6\u95f4\u5f88\u5c0f\uff0c\u5982\u679c\u7f3a\u5931\u7387\u6216\u7f3a\u5931\u4ee3\u4ef7\u5f88\u5927\uff0c\u6574\u4f53\u6027\u80fd\u4ecd\u7136\u4f1a\u5f88\u5dee\u3002</p>"},{"location":"posts/computer-organization/chapter5/#cache","title":"Cache \u7684\u4f5c\u7528","text":"<p>Cache \u4f4d\u4e8e CPU \u548c\u4e3b\u5b58\u4e4b\u95f4\uff0c\u7528\u8f83\u5c0f\u4f46\u66f4\u5feb\u7684 SRAM \u4fdd\u5b58\u8fd1\u671f\u53ef\u80fd\u4f1a\u88ab\u8bbf\u95ee\u7684\u6570\u636e\u3002\u5b83\u7684\u76ee\u6807\u4e0d\u662f\u4fdd\u5b58\u6240\u6709\u6570\u636e\uff0c\u800c\u662f\u5229\u7528\u5c40\u90e8\u6027\u8ba9\u201c\u5927\u591a\u6570\u8bbf\u95ee\u90fd\u547d\u4e2d\u201d\u3002</p> <p>\u5f15\u5165 Cache \u540e\uff0c\u6838\u5fc3\u95ee\u9898\u53d8\u6210\uff1a</p> <ol> <li>\u4e00\u4e2a\u5185\u5b58\u5757\u5e94\u8be5\u653e\u5728 Cache \u7684\u54ea\u91cc\uff1f</li> <li>CPU \u8bbf\u95ee\u67d0\u4e2a\u5730\u5740\u65f6\uff0c\u600e\u6837\u5224\u65ad\u5b83\u662f\u5426\u5728 Cache \u4e2d\uff1f</li> <li>\u5982\u679c Cache \u6ee1\u4e86\uff0c\u5e94\u8be5\u66ff\u6362\u54ea\u4e2a\u5757\uff1f</li> <li>\u5199\u64cd\u4f5c\u5e94\u8be5\u4ec0\u4e48\u65f6\u5019\u540c\u6b65\u5230\u4f4e\u5c42\u5b58\u50a8\uff1f</li> </ol>"},{"location":"posts/computer-organization/chapter5/#cache_1","title":"\u76f4\u63a5\u6620\u5c04 Cache","text":"<p><code>Direct Mapped Cache</code> \u662f\u6700\u7b80\u5355\u7684\u4e00\u79cd\u7ec4\u7ec7\u65b9\u5f0f\uff1a\u6bcf\u4e2a\u5185\u5b58\u5757\u53ea\u80fd\u653e\u5230 Cache \u4e2d\u552f\u4e00\u7684\u4e00\u884c\u3002</p> <p>\u6620\u5c04\u5173\u7cfb\u4e3a\uff1a</p> \\[ Index = Block\\ Address \\bmod Number\\ of\\ Cache\\ Blocks \\] <p>\u5982\u679c Cache \u884c\u6570\u662f 2 \u7684\u5e42\uff0c\u53d6\u6a21\u5c31\u7b49\u4ef7\u4e8e\u53d6\u5730\u5740\u4e2d\u7684\u82e5\u5e72\u4f4e\u4f4d\u4f5c\u4e3a <code>index</code>\u3002</p> <p>\u4e00\u4e2a\u5730\u5740\u901a\u5e38\u88ab\u62c6\u6210\u4e09\u90e8\u5206\uff1a</p> \u5b57\u6bb5 \u4f5c\u7528 Tag \u533a\u5206\u6620\u5c04\u5230\u540c\u4e00\u884c\u7684\u4e0d\u540c\u5185\u5b58\u5757 Index \u6307\u51fa\u8bbf\u95ee Cache \u7684\u54ea\u4e00\u884c Offset \u6307\u51fa\u5728 block \u5185\u8bbf\u95ee\u54ea\u4e00\u4e2a\u5b57\u8282\u6216\u5b57 <p>Cache \u884c\u4e2d\u8fd8\u9700\u8981\u4fdd\u5b58 <code>valid bit</code>\uff1a</p> <ul> <li><code>valid = 0</code>\uff1a\u8fd9\u4e00\u884c\u8fd8\u6ca1\u6709\u6709\u6548\u6570\u636e\u3002</li> <li><code>valid = 1</code>\uff1a\u8fd9\u4e00\u884c\u4fdd\u5b58\u7740\u53ef\u7528\u6570\u636e\uff0c\u9700\u8981\u7ee7\u7eed\u6bd4\u8f83 tag\u3002</li> </ul> <p>\u76f4\u63a5\u6620\u5c04 Cache \u7684\u8bbf\u95ee\u6d41\u7a0b\u53ef\u4ee5\u5199\u6210\uff1a</p> <ol> <li>\u7528 <code>index</code> \u627e\u5230\u552f\u4e00\u7684 Cache \u884c\u3002</li> <li>\u68c0\u67e5 valid bit \u662f\u5426\u4e3a 1\u3002</li> <li>\u6bd4\u8f83\u4fdd\u5b58\u7684 tag \u548c\u5730\u5740\u4e2d\u7684 tag\u3002</li> <li>\u5982\u679c valid \u4e3a 1 \u4e14 tag \u5339\u914d\uff0c\u5219 hit\u3002</li> <li>\u5426\u5219 miss\uff0c\u9700\u8981\u4ece\u4f4e\u5c42\u5b58\u50a8\u53d6\u56de\u5bf9\u5e94 block\u3002</li> </ol> <p>\u76f4\u63a5\u6620\u5c04\u7684\u4f18\u70b9\u662f\u786c\u4ef6\u7b80\u5355\u3001\u8bbf\u95ee\u5feb\uff1b\u7f3a\u70b9\u662f\u51b2\u7a81 miss \u660e\u663e\u3002\u4e24\u4e2a\u4e0d\u540c\u5185\u5b58\u5757\u5982\u679c index \u76f8\u540c\uff0c\u5c31\u4f1a\u53cd\u590d\u4e92\u76f8\u66ff\u6362\u3002</p>"},{"location":"posts/computer-organization/chapter5/#block-offset","title":"Block Offset \u4e0e\u5b57\u8282\u5bfb\u5740","text":"<p>\u5982\u679c\u4e00\u4e2a block \u4e2d\u5305\u542b\u591a\u4e2a word\uff0c\u90a3\u4e48 offset \u9700\u8981\u6307\u51fa block \u5185\u90e8\u5177\u4f53\u4f4d\u7f6e\u3002</p> <p>\u4ee5 64 \u4f4d\u7cfb\u7edf\u4e3a\u4f8b\uff0c\u5982\u679c\u4e00\u4e2a word \u662f 4B\uff0c\u90a3\u4e48\u4ece word offset \u8f6c\u6210 byte offset \u8fd8\u9700\u8981 2 \u4f4d\uff0c\u56e0\u4e3a\uff1a</p> \\[ 4B = 2^2B \\] <p>\u5982\u679c block \u4e2d\u6709 \\(2^m\\) \u4e2a word\uff0c\u90a3\u4e48\u9009\u62e9 word \u9700\u8981 \\(m\\) \u4f4d\uff1b\u518d\u9009\u62e9 word \u5185\u7684\u5b57\u8282\u9700\u8981 2 \u4f4d\uff0c\u6240\u4ee5 byte offset \u5171\u6709\uff1a</p> \\[ m + 2 \\] <p>\u8fd9\u4e5f\u662f\u5f88\u591a Cache \u5730\u5740\u62c6\u5206\u9898\u5bb9\u6613\u51fa\u9519\u7684\u5730\u65b9\uff1a\u9898\u76ee\u5230\u5e95\u662f\u5728\u8bf4 word offset\uff0c\u8fd8\u662f byte offset\u3002</p>"},{"location":"posts/computer-organization/chapter5/#_3","title":"\u865a\u62df\u5185\u5b58","text":"<p>\u7ee7\u7eed\u6cbf\u7740\u5c42\u6b21\u7ed3\u6784\u601d\u8003\uff1a\u65e2\u7136 Cache \u53ef\u4ee5\u628a\u4e3b\u5b58\u5f53\u4f5c\u4f4e\u5c42\u5b58\u50a8\uff0c\u90a3\u4e48\u4e3b\u5b58\u4e5f\u53ef\u4ee5\u4f5c\u4e3a\u78c1\u76d8\u7684 Cache\u3002</p> <p>\u8fd9\u5c31\u662f\u865a\u62df\u5185\u5b58\u7684\u57fa\u672c\u601d\u60f3\uff1a</p> <p>Main memory can act as a cache for secondary storage.</p> <p>\u7a0b\u5e8f\u770b\u5230\u7684\u662f <code>Virtual Address</code>\uff0c\u4e5f\u5c31\u662f\u865a\u62df\u5730\u5740\u3002\u865a\u62df\u5730\u5740\u4e0d\u662f\u6570\u636e\u5728\u771f\u5b9e\u5185\u5b58\u6761\u4e0a\u7684\u4f4d\u7f6e\u3002\u64cd\u4f5c\u7cfb\u7edf\u548c\u786c\u4ef6\u4f1a\u628a\u865a\u62df\u5730\u5740\u8f6c\u6362\u6210 <code>Physical Address</code>\uff0c\u518d\u8bbf\u95ee\u4e3b\u5b58\u3002</p> <p>\u865a\u62df\u5185\u5b58\u5e26\u6765\u7684\u597d\u5904\u5305\u62ec\uff1a</p> <ul> <li>\u8ba9\u6bcf\u4e2a\u7a0b\u5e8f\u770b\u8d77\u6765\u62e5\u6709\u8fde\u7eed\u3001\u72ec\u7acb\u7684\u5730\u5740\u7a7a\u95f4\u3002</li> <li>\u4fdd\u62a4\u4e0d\u540c\u8fdb\u7a0b\u7684\u5185\u5b58\u4e92\u4e0d\u5e72\u6270\u3002</li> <li>\u5141\u8bb8\u7a0b\u5e8f\u4f7f\u7528\u6bd4\u7269\u7406\u5185\u5b58\u66f4\u5927\u7684\u5730\u5740\u7a7a\u95f4\u3002</li> <li>\u8ba9\u4e0d\u5e38\u7528\u7684\u9875\u6682\u65f6\u653e\u5728\u78c1\u76d8\u4e2d\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter5/#page-page-fault","title":"Page \u4e0e Page Fault","text":"<p>\u5728\u865a\u62df\u5185\u5b58\u4e2d\uff0cblock \u901a\u5e38\u79f0\u4e3a <code>page</code>\u3002\u865a\u62df\u5730\u5740\u88ab\u62c6\u6210\u4e24\u90e8\u5206\uff1a</p> <ul> <li><code>Virtual Page Number</code>\uff0c\u865a\u62df\u9875\u53f7\u3002</li> <li><code>Page Offset</code>\uff0c\u9875\u5185\u504f\u79fb\u3002</li> </ul> <p>\u9875\u5185\u504f\u79fb\u7684\u4f4d\u6570\u51b3\u5b9a\u9875\u5927\u5c0f\u3002\u4f8b\u5982\u9875\u5185\u504f\u79fb\u662f 12 \u4f4d\uff0c\u5219\u9875\u5927\u5c0f\u4e3a\uff1a</p> \\[ 2^{12}B = 4096B = 4KiB \\] <p>\u5982\u679c\u8bbf\u95ee\u7684\u865a\u62df\u9875\u4e0d\u5728\u7269\u7406\u5185\u5b58\u4e2d\uff0c\u5c31\u4f1a\u53d1\u751f <code>page fault</code>\u3002Page fault \u7c7b\u4f3c Cache miss\uff0c\u4f46\u4ee3\u4ef7\u5927\u5f97\u591a\uff0c\u56e0\u4e3a\u53ef\u80fd\u9700\u8981\u8bbf\u95ee\u78c1\u76d8\u3002</p> <p>\u4e00\u6b21 Page Fault \u7684\u5178\u578b\u5904\u7406\u8fc7\u7a0b\uff1a</p> <ol> <li>CPU \u53d1\u73b0\u9875\u8868\u9879\u65e0\u6548\uff0c\u89e6\u53d1\u5f02\u5e38\u3002</li> <li>\u64cd\u4f5c\u7cfb\u7edf\u63a5\u7ba1\u63a7\u5236\u6743\u3002</li> <li>\u64cd\u4f5c\u7cfb\u7edf\u5728\u78c1\u76d8\u6216\u4ea4\u6362\u533a\u4e2d\u627e\u5230\u9700\u8981\u7684\u9875\u3002</li> <li>\u5982\u679c\u7269\u7406\u5185\u5b58\u5df2\u6ee1\uff0c\u9009\u62e9\u4e00\u4e2a\u9875\u6362\u51fa\u3002</li> <li>\u5982\u679c\u88ab\u6362\u51fa\u7684\u9875\u662f dirty \u7684\uff0c\u9700\u8981\u5199\u56de\u78c1\u76d8\u3002</li> <li>\u628a\u76ee\u6807\u9875\u8bfb\u5165\u7269\u7406\u5185\u5b58\u3002</li> <li>\u66f4\u65b0\u9875\u8868\u548c\u76f8\u5173\u72b6\u6001\u4f4d\u3002</li> <li>\u91cd\u65b0\u6267\u884c\u521a\u624d\u5931\u8d25\u7684\u6307\u4ee4\u3002</li> </ol> <p>\u56e0\u4e3a\u4e00\u6b21\u7f3a\u9875\u53ef\u80fd\u82b1\u8d39\u6570\u767e\u4e07\u4e2a\u65f6\u949f\u5468\u671f\uff0c\u6240\u4ee5\u865a\u62df\u5185\u5b58\u8bbe\u8ba1\u901a\u5e38\u91c7\u7528\uff1a</p> <ul> <li>\u8f83\u5927\u7684 page\uff0c\u5e38\u89c1\u4e3a 4KiB \u6216\u66f4\u5927\u3002</li> <li>\u66f4\u7075\u6d3b\u7684\u653e\u7f6e\u7b56\u7565\uff0c\u901a\u5e38\u63a5\u8fd1\u5168\u76f8\u8054\u3002</li> <li>\u8f6f\u4ef6\u5904\u7406\u7f3a\u9875\uff0c\u56e0\u4e3a\u78c1\u76d8\u5f00\u9500\u8fdc\u5927\u4e8e\u8f6f\u4ef6\u5904\u7406\u5f00\u9500\u3002</li> <li>\u5199\u56de\u7b56\u7565\uff0c\u7528 dirty bit \u907f\u514d\u6bcf\u6b21\u5199\u90fd\u540c\u6b65\u78c1\u76d8\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter5/#_4","title":"\u9875\u8868","text":"<p>\u9875\u8868\u662f\u865a\u62df\u9875\u53f7\u5230\u7269\u7406\u9875\u53f7\u7684\u6620\u5c04\u8868\u3002\u6bcf\u4e2a\u8fdb\u7a0b\u901a\u5e38\u6709\u81ea\u5df1\u7684\u9875\u8868\uff0cCPU \u4e2d\u4f1a\u6709\u9875\u8868\u5bc4\u5b58\u5668\u6307\u5411\u5f53\u524d\u8fdb\u7a0b\u9875\u8868\u7684\u8d77\u59cb\u4f4d\u7f6e\u3002</p> <p>\u5730\u5740\u7ffb\u8bd1\u6d41\u7a0b\u5982\u4e0b\uff1a</p> <ol> <li>CPU \u4ea7\u751f\u865a\u62df\u5730\u5740\u3002</li> <li>\u7528\u865a\u62df\u9875\u53f7 <code>VPN</code> \u67e5\u8be2\u9875\u8868\u3002</li> <li>\u68c0\u67e5\u9875\u8868\u9879\u4e2d\u7684 valid bit\u3002</li> <li>\u5982\u679c valid \u4e3a 1\uff0c\u53d6\u51fa\u7269\u7406\u9875\u53f7 <code>PPN</code>\u3002</li> <li>\u5c06 <code>PPN</code> \u4e0e\u539f\u6765\u7684 page offset \u62fc\u63a5\u6210\u7269\u7406\u5730\u5740\u3002</li> <li>\u5982\u679c valid \u4e3a 0\uff0c\u89e6\u53d1 page fault\u3002</li> </ol> <p>\u4f8b\u5982\uff0c48 \u4f4d\u865a\u62df\u5730\u5740\u30014KiB \u9875\u5927\u5c0f\u65f6\uff1a</p> <ul> <li>Page offset \u4e3a 12 \u4f4d\u3002</li> <li>VPN \u4e3a 36 \u4f4d\u3002</li> </ul> <p>\u5982\u679c\u7269\u7406\u5730\u5740\u662f 40 \u4f4d\uff0c\u5219\uff1a</p> <ul> <li>Page offset \u4ecd\u4e3a 12 \u4f4d\u3002</li> <li>PPN \u4e3a 28 \u4f4d\u3002</li> </ul> <p>\u7ffb\u8bd1\u65f6 offset \u4e0d\u53d8\uff0c\u53ea\u66ff\u6362\u9875\u53f7\u90e8\u5206\u3002</p>"},{"location":"posts/computer-organization/chapter5/#_5","title":"\u4e3a\u4ec0\u4e48\u9875\u8868\u4f1a\u5f88\u5927","text":"<p>\u5982\u679c\u865a\u62df\u5730\u5740\u662f 48 \u4f4d\uff0c\u9875\u5927\u5c0f\u662f 4KiB\uff0c\u5219 VPN \u6709 36 \u4f4d\uff0c\u4e5f\u5c31\u662f\u8bf4\u7406\u8bba\u4e0a\u9875\u8868\u53ef\u80fd\u6709\uff1a</p> \\[ 2^{36} \\] <p>\u4e2a\u6761\u76ee\u3002</p> <p>\u5982\u679c\u6bcf\u4e2a\u9875\u8868\u9879\u5360 8B\uff0c\u4ec5\u4e00\u5f20\u7ebf\u6027\u9875\u8868\u5c31\u53ef\u80fd\u9700\u8981\uff1a</p> \\[ 2^{36} \\times 8B = 512GiB \\] <p>\u8fd9\u663e\u7136\u4e0d\u53ef\u63a5\u53d7\u3002\u56e0\u6b64\u5b9e\u9645\u7cfb\u7edf\u4f1a\u4f7f\u7528\u591a\u7ea7\u9875\u8868\uff0c\u53ea\u4e3a\u771f\u6b63\u4f7f\u7528\u5230\u7684\u865a\u62df\u5730\u5740\u8303\u56f4\u5206\u914d\u9875\u8868\u9875\u3002</p>"},{"location":"posts/computer-organization/chapter5/#page-replacement-dirty-bit","title":"Page Replacement \u4e0e Dirty Bit","text":"<p>\u5f53\u53d1\u751f page fault \u800c\u7269\u7406\u5185\u5b58\u6ca1\u6709\u7a7a\u95f2\u9875\u65f6\uff0c\u64cd\u4f5c\u7cfb\u7edf\u5fc5\u987b\u9009\u62e9\u4e00\u4e2a\u9875\u6362\u51fa\u3002\u7406\u60f3\u76ee\u6807\u662f\u6362\u51fa\u672a\u6765\u6700\u4e45\u4e0d\u4f1a\u88ab\u8bbf\u95ee\u7684\u9875\uff0c\u4f46\u672a\u6765\u65e0\u6cd5\u51c6\u786e\u77e5\u9053\uff0c\u6240\u4ee5\u5e38\u7528\u8fc7\u53bb\u884c\u4e3a\u8fdb\u884c\u8fd1\u4f3c\u3002</p> <p><code>LRU</code>\uff0c\u4e5f\u5c31\u662f\u6700\u8fd1\u6700\u5c11\u4f7f\u7528\u7b56\u7565\uff0c\u57fa\u4e8e\u4e00\u4e2a\u5047\u8bbe\uff1a\u5f88\u4e45\u6ca1\u88ab\u8bbf\u95ee\u7684\u9875\uff0c\u77ed\u671f\u5185\u518d\u6b21\u8bbf\u95ee\u7684\u6982\u7387\u8f83\u4f4e\u3002</p> <p>\u5199\u56de\u7b56\u7565\u4e2d\uff0c\u6bcf\u4e2a\u9875\u901a\u5e38\u6709 dirty bit\uff1a</p> <ul> <li><code>dirty = 0</code>\uff1a\u9875\u6ca1\u6709\u88ab\u4fee\u6539\uff0c\u6362\u51fa\u65f6\u53ef\u4ee5\u76f4\u63a5\u4e22\u5f03\u3002</li> <li><code>dirty = 1</code>\uff1a\u9875\u88ab\u4fee\u6539\u8fc7\uff0c\u6362\u51fa\u524d\u5fc5\u987b\u5199\u56de\u78c1\u76d8\u3002</li> </ul> <p>\u8fd9\u6837\u53ef\u4ee5\u51cf\u5c11\u4e0d\u5fc5\u8981\u7684\u78c1\u76d8\u5199\u5165\u3002</p>"},{"location":"posts/computer-organization/chapter5/#tlb","title":"TLB","text":"<p><code>TLB</code> \u5168\u79f0\u662f <code>Translation Lookaside Buffer</code>\uff0c\u53ef\u4ee5\u7406\u89e3\u4e3a\u9875\u8868\u67e5\u8be2\u7684 Cache\uff0c\u7528\u6765\u52a0\u901f\u865a\u62df\u5730\u5740\u5230\u7269\u7406\u5730\u5740\u7684\u8f6c\u6362\u3002</p> <p>\u5982\u679c\u6bcf\u6b21\u8bbf\u5b58\u90fd\u8981\u5148\u8bbf\u95ee\u5185\u5b58\u4e2d\u7684\u9875\u8868\uff0c\u518d\u8bbf\u95ee\u771f\u6b63\u7684\u6570\u636e\uff0c\u90a3\u4e48\u4e00\u6b21\u5185\u5b58\u8bbf\u95ee\u4f1a\u53d8\u6210\u81f3\u5c11\u4e24\u6b21\u5185\u5b58\u8bbf\u95ee\u3002TLB \u4fdd\u5b58\u6700\u8fd1\u4f7f\u7528\u8fc7\u7684 VPN \u5230 PPN \u7684\u6620\u5c04\uff0c\u53ef\u4ee5\u663e\u8457\u964d\u4f4e\u5730\u5740\u7ffb\u8bd1\u5f00\u9500\u3002</p> <p>TLB \u8bbf\u95ee\u6d41\u7a0b\uff1a</p> <pre><code>VA = VPN + offset\n\n\u67e5 TLB\n  Hit:\n    PPN + offset -&gt; PA\n  Miss:\n    \u67e5\u9875\u8868\n      \u9875\u6709\u6548:\n        \u66f4\u65b0 TLB\n        PPN + offset -&gt; PA\n      \u9875\u65e0\u6548:\n        Page Fault\n        \u4ece Disk \u8c03\u9875\n        \u66f4\u65b0\u9875\u8868\u548c TLB\n        \u91cd\u65b0\u8bbf\u95ee\n</code></pre>"},{"location":"posts/computer-organization/chapter5/#_6","title":"\u5c0f\u7ed3","text":"<p>Chapter 5 \u53ef\u4ee5\u6293\u4f4f\u8fd9\u51e0\u4e2a\u5173\u952e\u8bcd\uff1a</p> <ul> <li>\u5b58\u50a8\u5668\u5c42\u6b21\u7ed3\u6784\u7528\u5c0f\u800c\u5feb\u7684\u4e0a\u5c42\u5b58\u50a8\u5f25\u8865\u5927\u800c\u6162\u7684\u4e0b\u5c42\u5b58\u50a8\u3002</li> <li>Cache \u4f9d\u8d56\u65f6\u95f4\u5c40\u90e8\u6027\u548c\u7a7a\u95f4\u5c40\u90e8\u6027\u3002</li> <li>\u76f4\u63a5\u6620\u5c04 Cache \u7528 index \u51b3\u5b9a\u552f\u4e00\u4f4d\u7f6e\uff0c\u7528 tag \u5224\u65ad\u662f\u5426\u5339\u914d\u3002</li> <li>\u865a\u62df\u5185\u5b58\u8ba9\u4e3b\u5b58\u6210\u4e3a\u78c1\u76d8\u7684 Cache\uff0c\u540c\u65f6\u63d0\u4f9b\u9694\u79bb\u548c\u4fdd\u62a4\u3002</li> <li>Page fault \u4ee3\u4ef7\u5f88\u9ad8\uff0c\u6240\u4ee5\u9875\u8f83\u5927\u3001\u66ff\u6362\u7b56\u7565\u66f4\u590d\u6742\u3001\u5e38\u7531\u8f6f\u4ef6\u5904\u7406\u3002</li> <li>TLB \u662f\u9875\u8868\u67e5\u8be2\u7684 Cache\uff0c\u7528\u6765\u52a0\u901f\u5730\u5740\u7ffb\u8bd1\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter6/","title":"\u8ba1\u7b97\u673a\u7ec4\u6210\u539f\u7406 Chapter 6\uff1a\u53ef\u9760\u6027\u3001RAID \u4e0e\u603b\u7ebf","text":"<p>\u8fd9\u7bc7\u7b14\u8bb0\u6574\u7406 Chapter 6 \u4e2d\u548c\u5b58\u50a8\u7cfb\u7edf\u3001\u53ef\u9760\u6027\u4ee5\u53ca\u603b\u7ebf\u6709\u5173\u7684\u6982\u5ff5\u3002\u6838\u5fc3\u95ee\u9898\u53ef\u4ee5\u6982\u62ec\u6210\u4e09\u53e5\u8bdd\uff1a</p> <ul> <li>\u7cfb\u7edf\u600e\u6837\u8861\u91cf\u201c\u591a\u4e45\u4f1a\u574f\u201d\u548c\u201c\u574f\u4e86\u591a\u4e45\u80fd\u4fee\u597d\u201d\uff1f</li> <li>\u78c1\u76d8\u9635\u5217\u4e3a\u4ec0\u4e48\u80fd\u540c\u65f6\u63d0\u5347\u5bb9\u91cf\u3001\u6027\u80fd\u548c\u53ef\u9760\u6027\uff1f</li> <li>\u603b\u7ebf\u600e\u6837\u628a CPU\u3001\u5185\u5b58\u548c I/O \u8bbe\u5907\u8fde\u63a5\u8d77\u6765\uff1f</li> </ul>"},{"location":"posts/computer-organization/chapter6/#_1","title":"\u53ef\u9760\u6027\u6307\u6807","text":"<p>\u53ef\u9760\u6027\u8ba8\u8bba\u7684\u662f\u7cfb\u7edf\u5728\u4e00\u5b9a\u65f6\u95f4\u5185\u6301\u7eed\u6b63\u5e38\u5de5\u4f5c\u7684\u80fd\u529b\u3002\u8003\u8bd5\u548c\u5de5\u7a0b\u8868\u8fbe\u91cc\u5e38\u89c1\u4e09\u4e2a\u6307\u6807\uff1a<code>MTTF</code>\u3001<code>MTTR</code> \u548c <code>MTBF</code>\u3002</p> \u6307\u6807 \u5168\u79f0 \u542b\u4e49 <code>MTTF</code> Mean Time To Failure \u5e73\u5747\u65e0\u6545\u969c\u5de5\u4f5c\u65f6\u95f4\uff0c\u8868\u793a\u7cfb\u7edf\u5e73\u5747\u8fd0\u884c\u591a\u4e45\u624d\u53d1\u751f\u4e00\u6b21\u6545\u969c <code>MTTR</code> Mean Time To Repair \u5e73\u5747\u4fee\u590d\u65f6\u95f4\uff0c\u8868\u793a\u7cfb\u7edf\u53d1\u751f\u6545\u969c\u540e\u5e73\u5747\u591a\u4e45\u53ef\u4ee5\u6062\u590d <code>MTBF</code> Mean Time Between Failures \u5e73\u5747\u6545\u969c\u95f4\u9694\u65f6\u95f4\uff0c\u901a\u5e38\u7528\u4e8e\u53ef\u4fee\u590d\u7cfb\u7edf <p>\u5bf9\u4e8e\u53ef\u4fee\u590d\u4ea7\u54c1\uff0c\u5e38\u7528\u5173\u7cfb\u662f\uff1a</p> \\[ MTBF = MTTF + MTTR \\] <p>\u9700\u8981\u6ce8\u610f\u7684\u662f\uff0c<code>MTTF</code> \u66f4\u5f3a\u8c03\u201c\u574f\u4e4b\u524d\u80fd\u5de5\u4f5c\u591a\u4e45\u201d\uff0c<code>MTTR</code> \u5f3a\u8c03\u201c\u574f\u4e86\u4e4b\u540e\u4fee\u591a\u4e45\u201d\uff0c\u800c <code>MTBF</code> \u5173\u6ce8\u4e24\u6b21\u6545\u969c\u4e4b\u95f4\u7684\u5e73\u5747\u95f4\u9694\u3002\u5b9e\u9645\u7cfb\u7edf\u4e2d\uff0c\u5982\u679c <code>MTTR</code> \u5f88\u5c0f\uff0c\u5373\u4f7f\u786c\u4ef6\u5076\u5c14\u6545\u969c\uff0c\u6574\u4f53\u53ef\u7528\u6027\u4e5f\u53ef\u80fd\u4ecd\u7136\u5f88\u9ad8\u3002</p>"},{"location":"posts/computer-organization/chapter6/#_2","title":"\u53ef\u7528\u6027","text":"<p>\u53ef\u7528\u6027\u53ef\u4ee5\u7406\u89e3\u4e3a\u201c\u7528\u6237\u9700\u8981\u7cfb\u7edf\u65f6\uff0c\u7cfb\u7edf\u5904\u4e8e\u53ef\u7528\u72b6\u6001\u7684\u6982\u7387\u201d\u3002\u4e00\u4e2a\u5e38\u89c1\u8fd1\u4f3c\u516c\u5f0f\u662f\uff1a</p> \\[ Availability = \\frac{MTTF}{MTTF + MTTR} \\] <p>\u4ece\u8fd9\u4e2a\u516c\u5f0f\u53ef\u4ee5\u770b\u51fa\uff0c\u63d0\u9ad8\u53ef\u7528\u6027\u6709\u4e24\u6761\u8def\uff1a</p> <ul> <li>\u589e\u5927 <code>MTTF</code>\uff1a\u8ba9\u7cfb\u7edf\u66f4\u4e0d\u5bb9\u6613\u574f\u3002</li> <li>\u51cf\u5c0f <code>MTTR</code>\uff1a\u8ba9\u7cfb\u7edf\u574f\u4e86\u4e4b\u540e\u66f4\u5feb\u6062\u590d\u3002</li> </ul> <p>\u539f\u59cb\u7b14\u8bb0\u91cc\u5199\u5230\u201c\u5982\u4f55\u51cf\u5c11 MTTF\u201d\uff0c\u8fd9\u91cc\u66f4\u51c6\u786e\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u201c\u5982\u4f55\u51cf\u5c11\u6545\u969c\u5f71\u54cd\uff0c\u6216\u8005\u63d0\u9ad8 MTTF\u201d\u3002\u5e38\u89c1\u65b9\u6cd5\u6709\u4e09\u7c7b\uff1a</p> <ol> <li><code>avoidance</code>\uff1a\u6545\u969c\u907f\u514d\u3002\u901a\u8fc7\u66f4\u53ef\u9760\u7684\u5668\u4ef6\u3001\u66f4\u597d\u7684\u6563\u70ed\u3001\u7535\u6e90\u4fdd\u62a4\u548c\u8d28\u91cf\u63a7\u5236\uff0c\u964d\u4f4e\u6545\u969c\u53d1\u751f\u6982\u7387\u3002</li> <li><code>tolerance</code>\uff1a\u6545\u969c\u5bb9\u5fcd\u3002\u901a\u8fc7\u5197\u4f59\u6280\u672f\u8ba9\u90e8\u5206\u7ec4\u4ef6\u574f\u6389\u65f6\u7cfb\u7edf\u4ecd\u53ef\u7ee7\u7eed\u5de5\u4f5c\u3002</li> <li><code>forecasting</code>\uff1a\u6545\u969c\u9884\u6d4b\u3002\u901a\u8fc7\u76d1\u63a7\u3001\u65e5\u5fd7\u548c\u5065\u5eb7\u68c0\u67e5\u63d0\u524d\u53d1\u73b0\u5f02\u5e38\uff0c\u907f\u514d\u5c0f\u95ee\u9898\u6269\u5927\u3002</li> </ol>"},{"location":"posts/computer-organization/chapter6/#raid","title":"\u4e3a\u4ec0\u4e48\u9700\u8981 RAID","text":"<p>\u5355\u5757\u786c\u76d8\u5bb9\u91cf\u6709\u9650\u3001\u6027\u80fd\u6709\u9650\uff0c\u4e5f\u53ef\u80fd\u635f\u574f\u3002RAID \u7684\u601d\u60f3\u662f\u628a\u591a\u5757\u78c1\u76d8\u7ec4\u7ec7\u6210\u4e00\u4e2a\u903b\u8f91\u78c1\u76d8\uff0c\u5bf9\u4e0a\u5c42\u7cfb\u7edf\u8868\u73b0\u5f97\u50cf\u4e00\u5757\u76d8\uff0c\u4f46\u5185\u90e8\u901a\u8fc7\u5e76\u884c\u8bbf\u95ee\u548c\u5197\u4f59\u5b58\u50a8\u63d0\u5347\u7cfb\u7edf\u80fd\u529b\u3002</p> <p><code>RAID</code> \u5168\u79f0\u662f <code>Redundant Arrays of Inexpensive Disks</code>\uff0c\u4e2d\u6587\u901a\u5e38\u7ffb\u8bd1\u4e3a\u5ec9\u4ef7\u78c1\u76d8\u5197\u4f59\u9635\u5217\u3002</p> <p>RAID \u89e3\u51b3\u7684\u4e3b\u8981\u95ee\u9898\u5305\u62ec\uff1a</p> <ul> <li>\u5bb9\u91cf\uff1a\u591a\u5757\u78c1\u76d8\u7ec4\u5408\u540e\u53ef\u4ee5\u5f62\u6210\u66f4\u5927\u7684\u903b\u8f91\u5b58\u50a8\u7a7a\u95f4\u3002</li> <li>\u6027\u80fd\uff1a\u6570\u636e\u5206\u6563\u5230\u591a\u5757\u78c1\u76d8\u540e\uff0c\u53ef\u4ee5\u5e76\u884c\u8bfb\u5199\u3002</li> <li>\u53ef\u9760\u6027\uff1a\u901a\u8fc7\u955c\u50cf\u6216\u6821\u9a8c\u4fe1\u606f\uff0c\u5728\u90e8\u5206\u78c1\u76d8\u635f\u574f\u65f6\u4ecd\u80fd\u6062\u590d\u6570\u636e\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter6/#raid_1","title":"\u5e38\u89c1 RAID \u7ea7\u522b","text":"\u7ea7\u522b \u4e3b\u8981\u601d\u60f3 \u4f18\u70b9 \u7f3a\u70b9 RAID 0 \u6761\u5e26\u5316\uff0c\u628a\u6570\u636e\u5206\u6563\u5199\u5165\u591a\u5757\u76d8 \u6027\u80fd\u597d\u3001\u5bb9\u91cf\u5229\u7528\u7387\u9ad8 \u6ca1\u6709\u5197\u4f59\uff0c\u4efb\u610f\u4e00\u5757\u76d8\u574f\u90fd\u4f1a\u4e22\u6570\u636e RAID 1 \u955c\u50cf\uff0c\u540c\u4e00\u4efd\u6570\u636e\u5199\u5165\u4e24\u5757\u76d8 \u53ef\u9760\u6027\u9ad8\uff0c\u8bfb\u6027\u80fd\u53ef\u63d0\u5347 \u5bb9\u91cf\u5229\u7528\u7387\u4f4e\uff0c\u6210\u672c\u8f83\u9ad8 RAID 4 \u5757\u7ea7\u6761\u5e26\u5316\uff0c\u4f7f\u7528\u4e13\u95e8\u6821\u9a8c\u76d8 \u53ef\u901a\u8fc7\u6821\u9a8c\u6062\u590d\u5355\u76d8\u6545\u969c \u6821\u9a8c\u76d8\u5bb9\u6613\u6210\u4e3a\u5199\u5165\u74f6\u9888 RAID 5 \u5206\u5e03\u5f0f\u6821\u9a8c\uff0c\u6821\u9a8c\u4fe1\u606f\u5206\u6563\u5728\u591a\u5757\u76d8 \u5bb9\u91cf\u3001\u6027\u80fd\u548c\u53ef\u9760\u6027\u8f83\u5747\u8861 \u5c0f\u5199\u5165\u6709\u6821\u9a8c\u5f00\u9500 RAID 6 \u53cc\u91cd\u5206\u5e03\u5f0f\u6821\u9a8c \u53ef\u4ee5\u5bb9\u5fcd\u4e24\u5757\u76d8\u540c\u65f6\u6545\u969c \u5199\u5165\u5f00\u9500\u548c\u5b9e\u73b0\u590d\u6742\u5ea6\u66f4\u9ad8 <p>\u4e00\u4e2a\u5bb9\u6613\u8003\u7684\u5224\u65ad\u662f\uff1aRAID 0 \u4e0d\u63d0\u4f9b\u53ef\u9760\u6027\u63d0\u5347\u3002\u5b83\u53ea\u662f\u628a\u6570\u636e\u5207\u5f00\u5e76\u884c\u653e\u5230\u4e0d\u540c\u78c1\u76d8\u4e0a\uff0c\u56e0\u6b64\u6027\u80fd\u66f4\u597d\uff0c\u4f46\u4efb\u610f\u4e00\u5757\u76d8\u635f\u574f\u90fd\u4f1a\u8ba9\u6574\u4f53\u6570\u636e\u4e0d\u53ef\u7528\u3002</p>"},{"location":"posts/computer-organization/chapter6/#_3","title":"\u4e24\u79cd\u786c\u76d8\u7ec4\u7ec7\u65b9\u5f0f\u7684\u6bd4\u8f83","text":"<p>\u5982\u679c\u7cfb\u7edf\u628a\u6570\u636e\u7b80\u5355\u62c6\u5206\u5230\u591a\u5757\u78c1\u76d8\u4e0a\uff0c\u4f46\u6ca1\u6709\u4efb\u4f55\u5197\u4f59\uff0c\u90a3\u4e48\u53ea\u8981\u5176\u4e2d\u4e00\u5757\u78c1\u76d8\u635f\u574f\uff0c\u6574\u4e2a\u6570\u636e\u96c6\u5408\u5c31\u53ef\u80fd\u4e0d\u53ef\u7528\u3002\u8fd9\u7c7b\u4f3c RAID 0 \u7684\u98ce\u9669\u3002</p> <p>\u5982\u679c\u7cfb\u7edf\u4fdd\u5b58\u4e86\u5197\u4f59\u6570\u636e\u6216\u6821\u9a8c\u4fe1\u606f\uff0c\u90a3\u4e48\u5728\u4e00\u5b9a\u8303\u56f4\u5185\u53ef\u4ee5\u627f\u53d7\u78c1\u76d8\u6545\u969c\u3002\u4f8b\u5982\u955c\u50cf\u53ef\u4ee5\u76f4\u63a5\u4f7f\u7528\u53e6\u4e00\u4efd\u526f\u672c\uff0c\u6821\u9a8c\u9635\u5217\u53ef\u4ee5\u901a\u8fc7\u5269\u4f59\u6570\u636e\u548c\u6821\u9a8c\u4fe1\u606f\u91cd\u5efa\u4e22\u5931\u5185\u5bb9\u3002</p> <p>\u56e0\u6b64\uff0c\u201c\u4f7f\u7528\u54ea\u79cd\u786c\u76d8\u7ec4\u7ec7\u65b9\u5f0f\u66f4\u597d\u201d\u8981\u770b\u76ee\u6807\uff1a</p> <ul> <li>\u53ea\u8ffd\u6c42\u901f\u5ea6\u548c\u5bb9\u91cf\uff1a\u53ef\u4ee5\u8003\u8651\u6761\u5e26\u5316\u3002</li> <li>\u8ffd\u6c42\u6570\u636e\u5b89\u5168\uff1a\u9700\u8981\u955c\u50cf\u6216\u6821\u9a8c\u3002</li> <li>\u8ffd\u6c42\u7efc\u5408\u5e73\u8861\uff1a\u5e38\u89c1\u9009\u62e9\u662f\u5e26\u5206\u5e03\u5f0f\u6821\u9a8c\u7684 RAID 5 \u6216 RAID 6\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter6/#_4","title":"\u603b\u7ebf","text":"<p>\u603b\u7ebf\u662f\u4e00\u5957\u8fde\u63a5\u591a\u4e2a\u5b50\u7cfb\u7edf\u7684\u7ebf\u8def\u548c\u534f\u8bae\u3002CPU\u3001\u5185\u5b58\u3001I/O \u63a7\u5236\u5668\u7b49\u90e8\u4ef6\u53ef\u4ee5\u901a\u8fc7\u603b\u7ebf\u4ea4\u6362\u5730\u5740\u3001\u6570\u636e\u548c\u63a7\u5236\u4fe1\u53f7\u3002</p> <p>\u4ece\u529f\u80fd\u4e0a\u770b\uff0c\u603b\u7ebf\u901a\u5e38\u5305\u542b\u4e09\u7c7b\u4fe1\u53f7\u7ebf\uff1a</p> <ul> <li>\u5730\u5740\u7ebf\uff1a\u6307\u51fa\u8981\u8bbf\u95ee\u7684\u4f4d\u7f6e\u6216\u8bbe\u5907\u3002</li> <li>\u6570\u636e\u7ebf\uff1a\u4f20\u8f93\u771f\u6b63\u7684\u6570\u636e\u3002</li> <li>\u63a7\u5236\u7ebf\uff1a\u8868\u793a\u8bfb\u3001\u5199\u3001\u4e2d\u65ad\u3001\u5e94\u7b54\u7b49\u63a7\u5236\u4fe1\u606f\u3002</li> </ul> <p>\u4e00\u6b21\u603b\u7ebf\u901a\u4fe1\u8fc7\u7a0b\u79f0\u4e3a <code>bus transaction</code>\u3002\u5b83\u901a\u5e38\u5305\u62ec\u53d1\u8d77\u8bf7\u6c42\u3001\u4f20\u8f93\u5730\u5740\u3001\u4f20\u8f93\u6570\u636e\u548c\u786e\u8ba4\u5b8c\u6210\u7b49\u6b65\u9aa4\u3002</p>"},{"location":"posts/computer-organization/chapter6/#_5","title":"\u540c\u6b65\u603b\u7ebf\u4e0e\u5f02\u6b65\u603b\u7ebf","text":"<p>\u540c\u6b65\u603b\u7ebf\u4f7f\u7528\u7edf\u4e00\u65f6\u949f\u534f\u8c03\u901a\u4fe1\u3002\u5404\u8bbe\u5907\u6309\u7167\u65f6\u949f\u8282\u62cd\u5b8c\u6210\u6570\u636e\u4f20\u8f93\u3002</p> <p>\u540c\u6b65\u603b\u7ebf\u7684\u7279\u70b9\u662f\uff1a</p> <ul> <li>\u63a7\u5236\u7b80\u5355\u3002</li> <li>\u901f\u5ea6\u5bb9\u6613\u9884\u6d4b\u3002</li> <li>\u5bf9\u8bbe\u5907\u901f\u5ea6\u4e00\u81f4\u6027\u8981\u6c42\u8f83\u9ad8\u3002</li> </ul> <p>\u5f02\u6b65\u603b\u7ebf\u4e0d\u4f9d\u8d56\u7edf\u4e00\u65f6\u949f\uff0c\u800c\u662f\u901a\u8fc7\u63e1\u624b\u534f\u8bae\u534f\u8c03\u901a\u4fe1\u3002\u5e38\u89c1\u8fc7\u7a0b\u662f\u8bf7\u6c42\u65b9\u53d1\u51fa <code>request</code>\uff0c\u63a5\u6536\u65b9\u51c6\u5907\u597d\u540e\u8fd4\u56de <code>acknowledge</code>\u3002</p> <p>\u5f02\u6b65\u603b\u7ebf\u7684\u7279\u70b9\u662f\uff1a</p> <ul> <li>\u53ef\u4ee5\u8fde\u63a5\u901f\u5ea6\u5dee\u5f02\u8f83\u5927\u7684\u8bbe\u5907\u3002</li> <li>\u63a7\u5236\u903b\u8f91\u6bd4\u540c\u6b65\u603b\u7ebf\u590d\u6742\u3002</li> <li>\u6bcf\u6b21\u4f20\u8f93\u9700\u8981\u7b49\u5f85\u63e1\u624b\u5b8c\u6210\u3002</li> </ul>"},{"location":"posts/computer-organization/chapter6/#_6","title":"\u5c0f\u7ed3","text":"<p>\u8fd9\u4e00\u7ae0\u53ef\u4ee5\u7528\u201c\u53ef\u9760\u6027 + \u5197\u4f59 + \u4e92\u8fde\u201d\u6765\u8bb0\uff1a</p> <ul> <li><code>MTTF</code>\u3001<code>MTTR</code>\u3001<code>MTBF</code> \u7528\u6765\u63cf\u8ff0\u6545\u969c\u548c\u4fee\u590d\u3002</li> <li>\u53ef\u7528\u6027\u4e0d\u4ec5\u53d6\u51b3\u4e8e\u591a\u4e45\u574f\u4e00\u6b21\uff0c\u4e5f\u53d6\u51b3\u4e8e\u574f\u4e86\u591a\u4e45\u80fd\u6062\u590d\u3002</li> <li>RAID \u901a\u8fc7\u591a\u76d8\u5e76\u884c\u548c\u5197\u4f59\u63d0\u5347\u5bb9\u91cf\u3001\u6027\u80fd\u548c\u53ef\u9760\u6027\u3002</li> <li>\u603b\u7ebf\u8d1f\u8d23\u5728\u7cfb\u7edf\u90e8\u4ef6\u4e4b\u95f4\u4f20\u8f93\u5730\u5740\u3001\u6570\u636e\u548c\u63a7\u5236\u4fe1\u53f7\u3002</li> <li>\u540c\u6b65\u603b\u7ebf\u9760\u65f6\u949f\uff0c\u5f02\u6b65\u603b\u7ebf\u9760\u63e1\u624b\u3002</li> </ul>"}]}